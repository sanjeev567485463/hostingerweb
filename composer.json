{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "astrotomic/laravel-translatable": "^11.12",
        "aws/aws-sdk-php": "^3.275",
        "barryvdh/laravel-debugbar": "^3.8",
        "barryvdh/laravel-dompdf": "^2.0",
        "carlos-meneses/laravel-mpdf": "^2.1",
        "chehivskiy/i18n-arabic": "^1.0",
        "craftsys/msg91-laravel": "^0.15.1",
        "cviebrock/eloquent-sluggable": "^10.0",
        "guzzlehttp/guzzle": "^7.2",
        "intervention/image": "^2.7",
        "james-heinrich/getid3": "^1.9",
        "jenssegers/agent": "^2.6",
        "joisarjignesh/bigbluebutton": "*",
        "jorenvanhocht/laravel-share": "^4.2",
        "jubaer/zoom-laravel": "^1.2",
        "kavenegar/laravel": "^1.3",
        "laravel/framework": "^10.48.29",
        "laravel/sanctum": "^3.0",
        "laravel/socialite": "^5.8",
        "laravel/tinker": "^2.7",
        "laravel/ui": "^4.2",
        "lasserafn/php-initial-avatar-generator": "^4.2",
        "league/csv": "^9.24",
        "league/flysystem": "^3.15",
        "league/flysystem-aws-s3-v3": "^3.15",
        "maatwebsite/excel": "^3.1",
        "mews/captcha": "^3.3",
        "mews/purifier": "^3.4",
        "niklasravnsborg/laravel-pdf": "^4.1",
        "openai-php/client": "v0.10.3",
        "openai-php/laravel": "v0.11.0",
        "php-http/guzzle7-adapter": "^1.0",
        "razorpay/razorpay": "^2.8",
        "saade/blade-iconsax": "^1.2.0",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/calendar-links": "^1.8",
        "spatie/laravel-google-calendar": "^3.6",
        "stichoza/google-translate-php": "^5.1",
        "stijnvanouplines/blade-country-flags": "^1.0",
        "torann/geoip": "^3.0",
        "toshy/bunnynet-php": "2.3.5",
        "twilio/sdk": "^7.5",
        "tymon/jwt-auth": "^2.0",
        "unisharp/laravel-filemanager": "2.9.1",
        "vonage/vonage-laravel": "^1.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "phpunit/phpunit": "^9.5.10",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/helper.php",
            "app/Mixins/Geo/Geo.php",
            "app/Helpers/ApiHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
